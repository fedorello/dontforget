# Database
# Dev: SQLite (auto-created)
DATABASE_URL=sqlite+aiosqlite:///./dontforget.db
# Prod (Railway PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dontforget

# AI — OpenRouter
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=x-ai/grok-4.1-fast
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_TOKENS=2000

# Storage (Cloudflare R2 / S3-compatible)
S3_BUCKET=dontforget-photos
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# App
APP_SECRET_KEY=change-me-in-production-use-random-32-chars
APP_DEBUG=true
APP_PORT=8787
ALLOWED_ORIGINS=http://localhost:9191,http://localhost:3000
